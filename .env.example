# ── CareNest Environment Variables ──────────────────────────────
# Detailed guide for setting up your production environment

# ── Backend Settings (Used by /backend/server.js)
# -------------------------------------------------------------
# PORT: The port the Node.js server listens on for local dev.
# Default is 5000. (Vercel ignores this).
PORT=5000

# MONGO_URI: Connection string for your MongoDB Atlas cluster.
# Format: mongodb+srv://<user>:<pass>@cluster0.abcde.mongodb.net/carenest
MONGO_URI=mongodb+srv://admin:password123@cluster0.mongodb.net/carenest

# JWT_SECRET: A secret string used to sign security tokens.
# Use a long, random string (e.g. 'carenest-super-secret-123!').
JWT_SECRET=your_super_secret_jwt_key

# CORS_ORIGIN: The URL of your frontend that is allowed to talk to the backend.
# In production, set this to your Vercel URL.
CORS_ORIGIN=https://care-nest-weld.vercel.app


# ── Frontend Settings (Used by Vite at build time)
# -------------------------------------------------------------
# VITE_API_BASE_URL: The URL where your backend API is hosted.
# Since we use a unified deployment, this is THE SAME as your Vercel URL.
# IMPORTANT: You must set this in Vercel settings before building.
VITE_API_BASE_URL=https://care-nest-weld.vercel.app
