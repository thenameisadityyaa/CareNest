# ── CareNest Environment Variables ──────────────────────────────

# ── Backend Settings
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/carenest
JWT_SECRET=your_super_secret_jwt_key
CORS_ORIGIN=https://your-carenest-app.vercel.app

# ── Frontend Settings (Vite requires VITE_ prefix)
VITE_API_BASE_URL=https://your-carenest-app.vercel.app
